PORT=4000
MONGODB_URL=your_mongodb_connection_string
JWT_SECRET=replace_with_a_long_random_secret

# SMTP: for Gmail, use a Google App Password (not your normal Gmail password).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_sender@gmail.com
MAIL_PASS=your_16_character_google_app_password

# Comma-separated client origins allowed to call this API.
FRONTEND_URL=https://your-vercel-project.vercel.app

RAZORPAY_KEY=rzp_test_your_key_id
RAZORPAY_SECRET=your_razorpay_key_secret

# Google OAuth Web Client ID. This exact same value is used in Vercel.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
